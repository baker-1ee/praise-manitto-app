rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // 1. [추가] 칭찬(praises) 컬렉션을 위한 정밀 보안 규칙
    match /praises/{praiseId} {  
      allow read: if request.auth != null && (    
        resource.data.fromUserId == request.auth.uid ||    
        resource.data.toUserId == request.auth.uid ||    
        get(/databases/$(database)/documents/sprints/$(resource.data.sprintId)).data.status in ['REVEALED', 'CLOSED']  
      );  
      allow create: if request.auth != null &&    
        request.resource.data.fromUserId == request.auth.uid;
    }

    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // all client requests to your Firestore database will be denied until you Update
    // your rules
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 24);
    }
  }
}