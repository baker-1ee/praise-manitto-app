rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 프로필 — 로그인한 누구나 읽기 (팀원 표시에 필요), 본인만 쓰기
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // 팀 — 로그인한 누구나 읽기 (초대 코드 조회에 필요), 생성자만 수정·삭제
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        resource.data.createdBy == request.auth.uid;
    }

    // 멤버십 — 로그인한 누구나 읽기 (팀원 목록 조회에 필요)
    //           본인 것만 생성, 본인 or 팀 생성자만 삭제 (팀 삭제 시 전체 삭제)
    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.createdBy == request.auth.uid
      );
      allow update: if false;
    }

    // 스프린트 — 로그인한 누구나 읽기, 생성은 팀 리더만, 수정·삭제도 팀 리더만
    match /sprints/{sprintId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data.createdBy == request.auth.uid;
      allow update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.createdBy == request.auth.uid;

      // 마니또 쌍 — 읽기 허용, 생성·삭제는 스프린트 생성자(리더)만
      //   생성: 같은 배치에서 만들어지는 sprints 문서는 get()으로 못 보므로
      //         pair 문서 자체에 실린 teamId로 팀 리더 여부를 확인
      match /pairs/{pairId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null &&
          get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data.createdBy == request.auth.uid;
        allow delete: if request.auth != null &&
          get(/databases/$(database)/documents/sprints/$(sprintId)).data.createdBy == request.auth.uid;
        allow update: if false;
      }
    }

    // 칭찬 — 로그인한 누구나 읽기, 본인이 보낸 것만 생성
    //        삭제는 스프린트 생성자(팀 삭제 시)만 허용
    //        수정은 작성자 본인이 작성 후 10분 이내에 content/categories만 변경 가능
    match /praises/{praiseId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.fromUserId == request.auth.uid;
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/sprints/$(resource.data.sprintId)).data.createdBy == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.fromUserId == request.auth.uid &&
        request.time < resource.data.createdAt + duration.value(10, 'm') &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content', 'categories']);
    }

    // 조르기 로그 — 본인 것만 생성, 본인 또는 스프린트 생성자(정리용)만 읽기,
    //             스프린트 생성자만 삭제 (팀 삭제 시)
    match /nudgeLogs/{nudgeId} {
      allow read: if request.auth != null && (
        resource.data.requesterId == request.auth.uid ||
        get(/databases/$(database)/documents/sprints/$(resource.data.sprintId)).data.createdBy == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.requesterId == request.auth.uid;
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/sprints/$(resource.data.sprintId)).data.createdBy == request.auth.uid;
      allow update: if false;
    }
  }
}