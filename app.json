{
  "expo": {
    "name": "칭찬 마니또",
    "slug": "praise-manitto-app",
    "owner": "studiojinung",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/images/whale-icon.png",
    "scheme": "praisemanittoapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jinung.praise.manitto",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.jinung.praise.manitto",
      "versionCode": 9,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#7c3aed",
        "foregroundImage": "./assets/images/whale-icon.png",
        "monochromeImage": "./assets/images/whale-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/whale-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/whale-icon.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/whale-splash.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.145966563075-d6mqtucb3pff9q7e3l59j2dk3iijba75"
        }
      ],
      "./plugins/withReleaseSigning"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "d6712af0-544a-4bb5-a4bc-3a992d11a563"
      }
    }
  }
}
